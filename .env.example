# Chat provider. Supported by the current architecture: demo, openai, anthropic.
# v1 development starts in deterministic demo mode.
ENGRAM_CHAT_PROVIDER=demo

# Set these to enable ChatGPT/OpenAI chat locally or in Vercel.
# OpenAI remains disabled unless OPENAI_LIVE_ENABLED=true.
OPENAI_LIVE_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional LLM planners for memory operations. These stay deterministic unless
# each planner is explicitly selected and enabled.
ENGRAM_MEMORY_PLANNER=deterministic
OPENAI_MEMORY_PLANNER_ENABLED=false
OPENAI_MEMORY_PLANNER_MODEL=gpt-5.4-mini
ENGRAM_CONSOLIDATION_PLANNER=deterministic
OPENAI_CONSOLIDATION_PLANNER_ENABLED=false
OPENAI_CONSOLIDATION_PLANNER_MODEL=gpt-5.4-mini

# Kept optional because the provider layer is neutral.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Public runtime defaults.
NEXT_PUBLIC_ENGRAM_DEMO_MODE=true
