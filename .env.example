# Root runtime configuration for localhost Engram Studio. The public web app in
# apps/web must not consume this file or any server-only values below.

# Chat provider. Implemented providers: demo, openai. Local development starts
# in deterministic demo mode.
ENGRAM_CHAT_PROVIDER=demo

# Set these to enable ChatGPT/OpenAI chat in local Studio.
# OpenAI remains disabled unless OPENAI_LIVE_ENABLED=true.
OPENAI_LIVE_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional LLM planners for memory operations. These stay deterministic unless
# each planner is explicitly selected and enabled.
ENGRAM_MEMORY_PLANNER=deterministic
OPENAI_MEMORY_PLANNER_ENABLED=false
OPENAI_MEMORY_PLANNER_MODEL=gpt-5.4-mini
ENGRAM_CONSOLIDATION_PLANNER=deterministic
OPENAI_CONSOLIDATION_PLANNER_ENABLED=false
OPENAI_CONSOLIDATION_PLANNER_MODEL=gpt-5.4-mini
ENGRAM_RETRIEVAL_PROVIDER=lexical
OPENAI_RETRIEVAL_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Browser-visible local Studio defaults.
NEXT_PUBLIC_ENGRAM_DEMO_MODE=true

# Process-local safety net for model-backed Studio routes.
ENGRAM_API_RATE_LIMIT_ENABLED=true

# Optional authenticated memory telemetry ingestion. Store only token hashes;
# clients send the corresponding raw token as a Bearer credential.
# ENGRAM_INGEST_KEYS_JSON=[{"keyId":"local-agent","tenantId":"tenant-local","projectId":"project-local","tokenSha256":"<sha256>"}]
ENGRAM_INGEST_KEYS_JSON=
ENGRAM_INGEST_ALLOWED_ORIGINS=

# Legacy, ephemeral Agents SDK flight recorder. It remains available without
# authentication in local development only when no ingest keys are configured.
# Production requires this explicit opt-in plus ENGRAM_INGEST_KEYS_JSON.
ENGRAM_LEGACY_LIVE_RECORDER_ENABLED=false

# Optional durable telemetry storage. These are server-only secrets. When they
# are absent, telemetry v2 uses an ephemeral in-process store for local work.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy fallback only; prefer SUPABASE_SECRET_KEY for new projects.
SUPABASE_SERVICE_ROLE_KEY=
