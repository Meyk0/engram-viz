{
  "name": "engram-viz",
  "version": "0.1.1",
  "description": "Open-source memory reliability and replay for AI agents.",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "predev": "npm run build:packages",
    "dev": "next dev --hostname 127.0.0.1",
    "dev:public": "npm run dev --workspace @engramviz/web --",
    "engram": "npm run build:packages && node packages/cli/bin/engram.mjs",
    "build:packages": "npm run build -w @engramviz/core && npm run build -w @engramviz/sdk && npm run build -w @engramviz/adapter-mem0 && npm run build -w @engramviz/adapter-langgraph && npm run build -w @engramviz/cli",
    "build:studio": "npm run build && node scripts/prepare-studio-package.mjs",
    "build:distribution": "npm run build:packages && npm run build:studio",
    "prebuild": "npm run build:packages",
    "build": "next build",
    "build:public": "npm run build --workspace @engramviz/web",
    "vercel-build": "node scripts/reject-root-vercel-deploy.mjs",
    "test:public": "npm run lint:public && npm run typecheck --workspace @engramviz/web && npm run test --workspace @engramviz/web --if-present && vitest run src/test/unit/public-web-boundary.test.ts",
    "lint:public": "npm run lint --workspace @engramviz/web",
    "sync:public-assets": "node scripts/sync-public-assets.mjs",
    "verify:public": "node scripts/verify-public-web.mjs",
    "start": "node scripts/prepare-studio-package.mjs && node scripts/start-local-studio.mjs",
    "lint": "eslint . --ignore-pattern 'apps/**'",
    "pretypecheck": "npm run build:packages",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:packages && vitest run",
    "eval:memory": "vitest run src/test/unit/memory-evals.test.ts --reporter=verbose",
    "test:regressions": "vitest run src/test/unit/checked-memory-regressions.test.ts --reporter=verbose",
    "test:example-real": "node --check examples/mem0-openai/demo.mjs",
    "test:example-langgraph": "node --check examples/langgraph-memory/demo.mjs",
    "test:example-regression": "npm run engram -- test regressions/current-city.engram-test.json --executor examples/mem0-stale-correction/regression-executor.mjs --format github",
    "release:check-public": "node scripts/check-public-release.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:lint": "cd docs && npx --yes mint@4.2.698 broken-links",
    "docs:dev": "cd docs && npx --yes mint@4.2.698 dev",
    "docs:preview": "cd docs && npx --yes mint@4.2.698 dev --no-open",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "smoke": "playwright test",
    "smoke:public": "playwright test --config playwright.public.config.ts",
    "test:distribution": "npm run build:distribution && node scripts/test-distribution.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Meyk0/engram-viz.git"
  },
  "keywords": [
    "llm",
    "memory",
    "observability",
    "reliability",
    "replay",
    "threejs",
    "visualization"
  ],
  "author": "Joscha Koepke",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Meyk0/engram-viz/issues"
  },
  "homepage": "https://github.com/Meyk0/engram-viz#readme",
  "dependencies": {
    "@engramviz/adapter-langgraph": "^0.1.1",
    "@engramviz/adapter-mem0": "^0.1.1",
    "@engramviz/core": "^0.1.1",
    "@engramviz/sdk": "^0.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "postprocessing": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.8",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.12"
  }
}
